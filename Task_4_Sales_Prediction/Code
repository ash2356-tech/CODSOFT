import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

from sklearn.model_selection import train_test_split
from sklearn.linear_model import LinearRegression
from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score

dataset_url = "https://raw.githubusercontent.com/ybifoundation/Dataset/main/Advertising.csv"
sales_data = pd.read_csv(dataset_url)

print("First 5 Rows:")
print(sales_data.head())

print("\nDataset Shape:", sales_data.shape)

print("\nMissing Values:")
print(sales_data.isnull().sum())

plt.figure(figsize=(6,4))
sns.heatmap(sales_data.corr(), annot=True)
plt.title("Correlation Matrix")
plt.show()

features = sales_data[['TV', 'Radio', 'Newspaper']]
target = sales_data['Sales']

x_train, x_test, y_train, y_test = train_test_split(
    features, target, test_size=0.2, random_state=42
)

sales_model = LinearRegression()
sales_model.fit(x_train, y_train)

predicted_sales = sales_model.predict(x_test)

print("\nModel Performance")
print("MAE:", mean_absolute_error(y_test, predicted_sales))
print("MSE:", mean_squared_error(y_test, predicted_sales))
print("R2 Score:", r2_score(y_test, predicted_sales))

plt.figure(figsize=(6,4))
plt.scatter(y_test, predicted_sales)
plt.xlabel("Actual Sales")
plt.ylabel("Predicted Sales")
plt.title("Actual vs Predicted Sales")
plt.show()

new_ad_data = pd.DataFrame({
    'TV': [230.1],
    'Radio': [37.8],
    'Newspaper': [69.2]
})

sales_prediction = sales_model.predict(new_ad_data)

print("\nPredicted Sales:", sales_prediction[0])
